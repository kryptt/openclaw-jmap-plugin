{
  "name": "@kryptt/openclaw-jmap-plugin",
  "version": "0.1.4",
  "description": "OpenClaw plugin: JMAP email integration \u2014 read/send/manage messages from any JMAP-compatible mail server",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kryptt/openclaw-jmap-plugin.git"
  },
  "dependencies": {
    "eventsource": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.5"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.4.5"
    },
    "build": {
      "openclawVersion": "2026.4.5"
    },
    "release": {
      "publishToClawHub": true
    }
  }
}
